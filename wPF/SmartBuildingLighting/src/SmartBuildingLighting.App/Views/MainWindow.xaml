<Window x:Class="SmartBuildingLighting.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartBuildingLighting.App.ViewModels"
        xmlns:views="clr-namespace:SmartBuildingLighting.App.Views"
        Title="SBL · Smart Building Lighting Control" Height="820" Width="1440"
        WindowStartupLocation="CenterScreen" MinHeight="720" MinWidth="1240"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:FloorMonitorViewModel}"><views:FloorMonitorView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ThreeDMonitorViewModel}"><views:ThreeDMonitorView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GroupControlViewModel}"><views:GroupControlView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SceneModeViewModel}"><views:SceneModeView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScheduleViewModel}"><views:ScheduleView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:EnergyStatsViewModel}"><views:EnergyStatsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewModel}"><views:LogView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
    </Window.Resources>
    <!-- 外层容器 -->
    <Border CornerRadius="6" Background="{StaticResource BgDeepBrush}"
            BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#00E5FF" BlurRadius="40" ShadowDepth="0" Opacity="0.25"/>
        </Border.Effect>
        <Grid>
            <!-- 背景层：径向渐变 + 网格线 -->
            <Border Background="{StaticResource BgRadialBrush}" CornerRadius="6"/>
            <Border Background="{StaticResource GridLinePattern}" CornerRadius="6" Opacity="0.5"/>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- ================= 顶部标题栏 ================= -->
                <Border Grid.Row="0" Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="6,6,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <!-- 顶部扫描线（动态） -->
                        <Border Style="{StaticResource ScanLineBorder}" VerticalAlignment="Bottom"/>
                        <Grid Margin="20,0">
                            <!-- 左侧 LOGO + 标题 -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- LOGO 方块（呼吸发光） -->
                                <Border Width="26" Height="26" CornerRadius="3"
                                        Background="{StaticResource AccentBrush}"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource GlowLogoBorder}">
                                    <TextBlock Text="S" Foreground="#041018" FontSize="15" FontWeight="Bold"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="智能楼宇照明监控系统" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontFamily="{StaticResource DisplayFontFamily}"/>
                                        <Border Width="1" Height="12" Background="{StaticResource PrimaryLightBrush}"
                                                Margin="12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="SBL-MCS v1.0" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding CurrentPageTitle}"
                                               Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- 右侧 系统状态 + 用户 + 窗口控制 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- UPTIME 运行时长 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="UPTIME" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding UptimeDisplay, FallbackValue='00:00:00'}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <!-- 实时时钟 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="◯" Foreground="{StaticResource AccentBrush}" FontSize="9" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentTimeDisplay, FallbackValue='—:—:—'}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                                <!-- 分隔符 -->
                                <Border Width="1" Height="16" Background="{StaticResource PrimaryLightBrush}"
                                        Margin="0,0,16,0"/>
                                <!-- 系统状态指示 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                                    <Ellipse Style="{StaticResource StatusDotOnline}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SYSTEM ONLINE" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource SuccessBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <!-- 分隔符 -->
                                <Border Width="1" Height="16" Background="{StaticResource PrimaryLightBrush}"
                                        Margin="0,0,20,0"/>
                                <!-- 用户信息 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                                    <TextBlock Text="{Binding UserName}" Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               FontFamily="{StaticResource DisplayFontFamily}"/>
                                    <Border Background="#151C3555" CornerRadius="3" Padding="8,3" Margin="10,0,0,0"
                                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserRole}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="{StaticResource MonoFontFamily}"/>
                                    </Border>
                                </StackPanel>
                                <Button Content="LOGOUT" Click="LogoutButton_Click"
                                        Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="10"
                                        Margin="0,0,16,0"/>
                                <!-- 窗口控制 -->
                                <Button Content="—" Click="MinimizeButton_Click" Style="{StaticResource TitleBarButton}"/>
                                <Button Content="□" Click="MaximizeButton_Click" Style="{StaticResource TitleBarButton}"/>
                                <Button Content="✕" Click="CloseButton_Click" Style="{StaticResource CloseBarButton}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <!-- ================= 主内容区 ================= -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- ==== 左侧导航栏 ==== -->
                    <Border Grid.Column="0" Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="0,0,1,0"
                            Padding="0,20,0,16">
                        <Grid>
                            <StackPanel>
                                <!-- 导航分组标签 -->
                                <StackPanel Orientation="Horizontal" Margin="20,0,0,14">
                                    <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                    <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               ToolTip="导航菜单"/>
                                </StackPanel>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="Dashboard">
                                    <Button.Tag>Dashboard</Button.Tag>
                                    <Button.Background>
                                        <MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background">
                                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                                            <Binding Path="CurrentPageKey"/>
                                        </MultiBinding>
                                    </Button.Background>
                                    <Button.BorderBrush>
                                        <MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border">
                                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                                            <Binding Path="CurrentPageKey"/>
                                        </MultiBinding>
                                    </Button.BorderBrush>
                                    <Button.Foreground>
                                        <MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground">
                                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                                            <Binding Path="CurrentPageKey"/>
                                        </MultiBinding>
                                    </Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="◈"/>
                                        <Run Text="  仪表盘"/>
                                    </TextBlock>
                                </Button>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="FloorMonitor" Margin="0,4,0,0">
                                    <Button.Tag>FloorMonitor</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="▤"/>
                                        <Run Text="  楼层监控"/>
                                    </TextBlock>
                                </Button>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="ThreeDMonitor" Margin="0,4,0,0">
                                    <Button.Tag>ThreeDMonitor</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="◬"/>
                                        <Run Text="  三维监控"/>
                                    </TextBlock>
                                </Button>
                                <!-- 管理员分组标签 -->
                                <StackPanel Orientation="Horizontal" Margin="20,22,0,12">
                                    <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                    <TextBlock Text="CONTROL" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="GroupControl">
                                    <Button.Tag>GroupControl</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="◉"/>
                                        <Run Text="  分组控制"/>
                                    </TextBlock>
                                    <Button.Visibility>
                                        <Binding Path="IsAdmin" Converter="{StaticResource BoolToVisibility}"/>
                                    </Button.Visibility>
                                </Button>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="SceneMode" Margin="0,4,0,0">
                                    <Button.Tag>SceneMode</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="✦"/>
                                        <Run Text="  情景模式"/>
                                    </TextBlock>
                                    <Button.Visibility>
                                        <Binding Path="IsAdmin" Converter="{StaticResource BoolToVisibility}"/>
                                    </Button.Visibility>
                                </Button>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="Schedule" Margin="0,4,0,0">
                                    <Button.Tag>Schedule</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="⏱"/>
                                        <Run Text="  定时调度"/>
                                    </TextBlock>
                                    <Button.Visibility>
                                        <Binding Path="IsAdmin" Converter="{StaticResource BoolToVisibility}"/>
                                    </Button.Visibility>
                                </Button>
                                <!-- 分析分组 -->
                                <StackPanel Orientation="Horizontal" Margin="20,22,0,12">
                                    <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                    <TextBlock Text="ANALYTICS" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="EnergyStats">
                                    <Button.Tag>EnergyStats</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="◭"/>
                                        <Run Text="  能耗统计"/>
                                    </TextBlock>
                                </Button>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="Log" Margin="0,4,0,0">
                                    <Button.Tag>Log</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="≡"/>
                                        <Run Text="  操作日志"/>
                                    </TextBlock>
                                </Button>
                                <Border Height="1" Background="{StaticResource PrimaryLightBrush}" Margin="16,22"/>
                                <Button Style="{StaticResource NavButton}" Command="{Binding NavigateToCommand}" CommandParameter="Settings">
                                    <Button.Tag>Settings</Button.Tag>
                                    <Button.Background><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Background"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Background>
                                    <Button.BorderBrush><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Border"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.BorderBrush>
                                    <Button.Foreground><MultiBinding Converter="{StaticResource PageKeyStateBrush}" ConverterParameter="Foreground"><Binding RelativeSource="{RelativeSource Self}" Path="Tag"/><Binding Path="CurrentPageKey"/></MultiBinding></Button.Foreground>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="⚙"/>
                                        <Run Text="  系统设置"/>
                                    </TextBlock>
                                    <Button.Visibility>
                                        <Binding Path="IsAdmin" Converter="{StaticResource BoolToVisibility}"/>
                                    </Button.Visibility>
                                </Button>
                            </StackPanel>
                            <!-- 底部版本信息 -->
                            <Border VerticalAlignment="Bottom" Margin="20,0,20,0"
                                    Background="#200F1E36"
                                    BorderBrush="{StaticResource PrimaryLightBrush}"
                                    BorderThickness="1" CornerRadius="3" Padding="12,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="v1.0.0" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="{StaticResource MonoFontFamily}"/>
                                        <TextBlock Text="· BUILD 2026.04" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="周文旭 · 毕业设计" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="{StaticResource DisplayFontFamily}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- ==== 右侧内容区（带网格底 + 径向渐变） ==== -->
                    <Grid Grid.Column="1">
                        <!-- 背景装饰层 -->
                        <Border Background="{StaticResource BgDarkBrush}"/>
                        <Border Background="{StaticResource GridDotPattern}" Opacity="0.4"/>
                        <!-- 内容 -->
                        <ContentControl Content="{Binding NavigationService.CurrentViewModel}"
                                        Margin="30,24"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
