<Window x:Class="SmartBuildingLighting.App.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智能楼宇照明监控系统 - 登录" Height="640" Width="980"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="6" Background="{StaticResource BgDeepBrush}"
            BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#00E5FF" BlurRadius="48" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>
        <Grid>
            <!-- 整体背景 -->
            <Border Background="{StaticResource BgRadialBrush}" CornerRadius="6"/>
            <Border Background="{StaticResource GridLinePattern}" CornerRadius="6" Opacity="0.55"/>
            <!-- 顶部扫描线 -->
            <Border Style="{StaticResource ScanLineBorder}" VerticalAlignment="Top"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>
                <!-- ============ 左侧品牌区 ============ -->
                <Border Grid.Column="0" Background="{StaticResource BrandPanelGradient}" CornerRadius="6,0,0,6"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <!-- 网格点阵背景 -->
                        <Border Background="{StaticResource GridDotPattern}" Opacity="0.5"/>
                        <!-- 装饰同心圆 -->
                        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,40">
                            <Ellipse Width="320" Height="320" Stroke="#2000E5FF" StrokeThickness="1" Fill="Transparent"/>
                            <Ellipse Width="230" Height="230" Stroke="#3000E5FF" StrokeThickness="1" Fill="Transparent"/>
                            <Ellipse Width="140" Height="140" Stroke="#4500E5FF" StrokeThickness="1" Fill="Transparent"/>
                        </Grid>
                        <!-- 右下角状态标签 -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,40"
                                Background="#300F1E36" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                CornerRadius="3" Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Style="{StaticResource StatusDotOnline}" VerticalAlignment="Center"/>
                                <TextBlock Text="SYSTEM READY" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Margin="56" VerticalAlignment="Center">
                            <!-- 科技感标头 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="4" Height="20" Background="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="SBL · MONITORING · CONTROL · SYSTEM"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <!-- Logo 方块（呼吸发光 + 动态脉冲环） -->
                            <Grid HorizontalAlignment="Left" Margin="0,0,0,32">
                                <Ellipse Style="{StaticResource PulseRing}" Width="64" Height="64" Stroke="{StaticResource AccentBrush}"/>
                                <Border Width="64" Height="64" CornerRadius="6"
                                        Background="{StaticResource AccentBrush}"
                                        Style="{StaticResource GlowLogoBorder}">
                                    <Grid>
                                        <Path Data="M12,4 L12,20 M20,12 L4,12 M18,6 L6,18 M18,18 L6,6"
                                              Stroke="#041018" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Width="24" Height="24" Stretch="Uniform"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            <!-- 标题 -->
                            <TextBlock Text="智能楼宇照明"
                                       FontSize="40" FontWeight="Light"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource DisplayFontFamily}"/>
                            <TextBlock Text="监控系统"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="{StaticResource DisplayFontFamily}">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00E5FF" BlurRadius="18" ShadowDepth="0" Opacity="0.55"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <!-- 副标题 -->
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Border Width="60" Height="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="INTELLIGENT  LIGHTING  CONTROL"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </StackPanel>
                            <!-- 特性卡片 -->
                            <UniformGrid Columns="2" Margin="0,34,0,0">
                                <Border Background="#300F1E36"
                                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="14" Margin="0,0,10,10">
                                    <Grid>
                                        <Path Style="{StaticResource CornerClipTL}"/>
                                        <StackPanel Margin="4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="01" FontSize="11" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontFamily="{StaticResource MonoFontFamily}"/>
                                                <TextBlock Text="· MONITOR" FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="{StaticResource MonoFontFamily}" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="可视监控" Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                            <TextBlock Text="2D / 3D 楼层状态联动" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Background="#300F1E36"
                                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="14" Margin="0,0,0,10">
                                    <Grid>
                                        <Path Style="{StaticResource CornerClipTL}"/>
                                        <StackPanel Margin="4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="02" FontSize="11" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontFamily="{StaticResource MonoFontFamily}"/>
                                                <TextBlock Text="· CONTROL" FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontFamily="{StaticResource MonoFontFamily}" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="统一控制" Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                            <TextBlock Text="分组、情景、调度统一入口" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </UniformGrid>
                            <!-- 机构标签 -->
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <TextBlock Text="◈" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="JLJU · 吉林建筑大学" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- ============ 右侧登录表单 ============ -->
                <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" CornerRadius="0,6,6,0">
                    <Grid>
                        <Border Background="{StaticResource GridLinePattern}" Opacity="0.3"/>
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Style="{StaticResource CloseBarButton}" Click="CloseButton_Click"
                                Margin="12,12,12,0"/>
                        <Grid Margin="50,20,50,40">
                            <StackPanel VerticalAlignment="Center" MaxWidth="320">
                                <!-- 头标 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="3" Height="14" Background="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SECURE · LOGIN" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="登录控制台"
                                           FontSize="32" FontWeight="Light"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="{StaticResource DisplayFontFamily}"/>
                                <TextBlock Text="Access control authentication required"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Margin="0,6,0,30"/>
                                <!-- 用户名 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="▸" Foreground="{StaticResource AccentBrush}" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="USER · 用户名" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,22" Height="42"/>
                                <!-- 密码 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="▸" Foreground="{StaticResource AccentBrush}" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="PASS · 密码" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,14" Height="42"/>
                                <!-- 错误消息 -->
                                <Border Background="#301A0A14"
                                        BorderBrush="{StaticResource DangerBrush}" BorderThickness="1"
                                        CornerRadius="3" Padding="10,7"
                                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Style="{StaticResource StatusDotDanger}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ErrorMessage}"
                                                   Foreground="{StaticResource DangerBrush}"
                                                   FontSize="12"
                                                   FontFamily="{StaticResource DisplayFontFamily}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <!-- 登录按钮 -->
                                <Button Content="登  录  ▸  ENTER" Style="{StaticResource PrimaryButton}"
                                        Click="LoginButton_Click"
                                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                        HorizontalAlignment="Stretch" Margin="0,10,0,0"
                                        Height="46" FontSize="13"/>
                                <!-- 底部提示 -->
                                <Border Background="#200F1E36"
                                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                                        CornerRadius="3" Padding="12,10" Margin="0,22,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ⓘ" Foreground="{StaticResource AccentBrush}" FontSize="13" VerticalAlignment="Top"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="DEFAULT CREDENTIALS" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontFamily="{StaticResource MonoFontFamily}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                       Margin="0,4,0,0">
                                                <Run Text="admin" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                <Run Text=" / "/>
                                                <Run Text="admin123" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
