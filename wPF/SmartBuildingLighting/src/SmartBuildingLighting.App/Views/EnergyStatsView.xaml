<UserControl x:Class="SmartBuildingLighting.App.Views.EnergyStatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SmartBuildingLighting.App.Controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Loaded="UserControl_Loaded">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <controls:PageHeader Title="能耗统计" Code="ANALYTICS / ENERGY"
                                     Subtitle="历史能耗数据查询 · 支持按时间区间筛选并导出 CSV">
                    <controls:PageHeader.HeaderActions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <DatePicker SelectedDate="{Binding StartDate}" Width="130" Margin="0,0,8,0"/>
                            <TextBlock Text="→" Foreground="{StaticResource AccentBrush}" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontFamily="{StaticResource MonoFontFamily}"/>
                            <DatePicker SelectedDate="{Binding EndDate}" Width="130" Margin="0,0,12,0"/>
                            <Button Content="▸ 查询" Style="{StaticResource PrimaryButton}" Command="{Binding LoadDataCommand}" Padding="16,6" FontSize="11"/>
                            <Button Content="⤓ CSV" Style="{StaticResource SecondaryButton}" Command="{Binding ExportCsvCommand}" Padding="16,6" FontSize="11" Margin="8,0,0,0"/>
                        </StackPanel>
                    </controls:PageHeader.HeaderActions>
                </controls:PageHeader>
                <!-- 总能耗卡片 -->
                <Border Background="{StaticResource CardBgGradientBrush}"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="24,20" Margin="0,0,0,18">
                    <Grid>
                        <!-- 顶部 accent -->
                        <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                Background="{StaticResource AccentBrush}" Opacity="0.6"/>
                        <Path Style="{StaticResource CornerClipTL}"/>
                        <Path Style="{StaticResource CornerClipTR}"/>
                        <Path Style="{StaticResource CornerClipBL}"/>
                        <Path Style="{StaticResource CornerClipBR}"/>
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                    <TextBlock Text="TOTAL · ENERGY CONSUMPTION" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="查询期间总能耗" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding TotalEnergy, StringFormat=F1}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="44" FontWeight="Bold"
                                               FontFamily="{StaticResource MonoFontFamily}">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0" Opacity="0.6"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="kWh" Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="18"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Bottom" Margin="10,0,0,8"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom"
                                        Visibility="{Binding ExportPath, Converter={StaticResource NullToVisibility}}">
                                <Border Background="#300F1E36"
                                        BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                        CornerRadius="3" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Style="{StaticResource StatusDotOnline}" VerticalAlignment="Center"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="EXPORT · DONE" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       FontFamily="{StaticResource MonoFontFamily}"/>
                                            <TextBlock Text="{Binding ExportPath}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10"
                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <!-- 日能耗趋势 -->
                <Border Background="{StaticResource CardBgGradientBrush}"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="20,18" Margin="0,0,0,16">
                    <Grid>
                        <Path Style="{StaticResource CornerClipTL}"/>
                        <Path Style="{StaticResource CornerClipBR}"/>
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="TREND · DAILY" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"/>
                                <Border Width="80" Height="1" Background="{StaticResource PrimaryLightBrush}"
                                        VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="日能耗趋势" Style="{StaticResource SectionTitle}" Margin="0,0,0,14"/>
                            <lvc:CartesianChart Series="{Binding DailySeries}"
                                                XAxes="{Binding DailyXAxes}"
                                                YAxes="{Binding DailyYAxes}"
                                                Height="260" Background="Transparent"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- 楼层能耗 + TOP10 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Margin="0,0,12,0"
                            Background="{StaticResource CardBgGradientBrush}"
                            BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="20,18">
                        <Grid>
                            <Path Style="{StaticResource CornerClipTL}"/>
                            <Path Style="{StaticResource CornerClipBR}"/>
                            <StackPanel Margin="6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="COMPARE · FLOOR" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"/>
                                </StackPanel>
                                <TextBlock Text="楼层能耗对比" Style="{StaticResource SectionTitle}" Margin="0,0,0,14"/>
                                <lvc:CartesianChart Series="{Binding FloorSeries}"
                                                    XAxes="{Binding FloorXAxes}"
                                                    YAxes="{Binding FloorYAxes}"
                                                    Height="320" Background="Transparent"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Margin="12,0,0,0"
                            Background="{StaticResource CardBgGradientBrush}"
                            BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="20,18">
                        <Grid>
                            <Path Style="{StaticResource CornerClipTL}"/>
                            <Path Style="{StaticResource CornerClipBR}"/>
                            <StackPanel Margin="6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="RANKING · TOP 10" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"/>
                                </StackPanel>
                                <TextBlock Text="回路能耗排行" Style="{StaticResource SectionTitle}" Margin="0,0,0,14"/>
                                <ItemsControl ItemsSource="{Binding TopCircuits}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#200F1E36"
                                                    BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                                                    CornerRadius="3" Padding="10,8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="32"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="22" Height="22" CornerRadius="3"
                                                            Background="#300F1E36"
                                                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                                                        <TextBlock Text="{Binding Rank}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="12" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" Margin="10,0"/>
                                                    <TextBlock Grid.Column="2"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               FontFamily="{StaticResource MonoFontFamily}"
                                                               VerticalAlignment="Center" HorizontalAlignment="Right">
                                                        <Run Text="{Binding Energy, StringFormat=F1}"/>
                                                        <Run Text=" kWh" Foreground="{StaticResource TextMutedBrush}"/>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Padding="16" Background="#200F1E36"
                                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                                        CornerRadius="3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TopCircuits.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="NO DATA" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="暂无排行数据"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
        <Border Background="#CC040812"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="64" Height="64">
                    <Ellipse Style="{StaticResource RotatingArc}" Width="64" Height="64"/>
                    <Ellipse Style="{StaticResource PulseRing}" Width="30" Height="30"/>
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
                <TextBlock Text="COMPUTING · STATS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource MonoFontFamily}"
                           HorizontalAlignment="Center" Margin="0,22,0,0"/>
                <TextBlock Text="正在计算能耗统计"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
