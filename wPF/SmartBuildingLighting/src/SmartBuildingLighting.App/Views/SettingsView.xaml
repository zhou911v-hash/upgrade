<UserControl x:Class="SmartBuildingLighting.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SmartBuildingLighting.App.Controls"
             Loaded="UserControl_Loaded">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="680">
                <controls:PageHeader Title="系统设置" Code="SYSTEM / CONFIG"
                                     Subtitle="通信参数配置 · 用户密码管理 · 系统信息查看"/>
                <!-- ===== 通信参数配置 ===== -->
                <Border Background="{StaticResource CardBgGradientBrush}"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="24,20" Margin="0,0,0,16">
                    <Grid>
                        <Path Style="{StaticResource CornerClipTL}"/>
                        <Path Style="{StaticResource CornerClipBR}"/>
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                <TextBlock Text="COMMUNICATION · CONFIG" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="通信参数配置" Style="{StaticResource SectionTitle}"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PROFILE · NAME" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MODE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding CommunicationModes}" SelectedItem="{Binding SelectedMode}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource CommunicationModeDisplay}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="HOST · PORT" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ServerHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBox Grid.Column="2" Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="UNIT · INTERVAL" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding UnitId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBox Grid.Column="2" Text="{Binding TelemetryIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="COIL · BRIGHT" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding CoilBaseAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBox Grid.Column="2" Text="{Binding BrightnessRegisterBase, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CURR · POW" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding CurrentRegisterBase, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBox Grid.Column="2" Text="{Binding PowerRegisterBase, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <!-- 连接状态 -->
                            <Border Background="{StaticResource BgLightBrush}"
                                    BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                                    CornerRadius="3" Padding="14,10" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CONNECTION · STATUS" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Fill="{Binding IsConnected, Converter={StaticResource BoolToColor}}" Margin="0,0,8,0">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#00FF88" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <TextBlock Text="{Binding ConnectionStatus}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="保存配置" Style="{StaticResource SecondaryButton}" Command="{Binding SaveProfileCommand}" Padding="22,8" FontSize="12" Margin="0,0,8,0"/>
                                <Button Content="连接" Style="{StaticResource SuccessButton}" Command="{Binding ConnectCommand}" Padding="22,8" FontSize="12" Margin="0,0,8,0"/>
                                <Button Content="断开" Style="{StaticResource DangerButton}" Command="{Binding DisconnectCommand}" Padding="22,8" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- ===== 修改密码 ===== -->
                <Border Background="{StaticResource CardBgGradientBrush}"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="24,20" Margin="0,0,0,16">
                    <Grid>
                        <Path Style="{StaticResource CornerClipTL}"/>
                        <Path Style="{StaticResource CornerClipBR}"/>
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                <TextBlock Text="SECURITY · PASSWORD" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="修改密码" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="原密码 · OLD" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="OldPwdBox" Margin="0,0,0,12"/>
                            <TextBlock Text="新密码 · NEW" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="NewPwdBox" Margin="0,0,0,16"/>
                            <Button Content="修改密码" Style="{StaticResource PrimaryButton}" Click="ChangePassword_Click" Padding="22,8" FontSize="12" HorizontalAlignment="Left" IsEnabled="{Binding IsAdmin}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Background="#300F1E36"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                        CornerRadius="3" Padding="12,8" Margin="0,0,0,16"
                        Visibility="{Binding Message, Converter={StaticResource NullToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Message}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <!-- ===== 关于系统 ===== -->
                <Border Background="{StaticResource CardBgGradientBrush}"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="24,20">
                    <Grid>
                        <Path Style="{StaticResource CornerClipTL}"/>
                        <Path Style="{StaticResource CornerClipBR}"/>
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                <TextBlock Text="ABOUT · SYSTEM" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="关于系统" Style="{StaticResource SectionTitle}"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="SYSTEM"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="智能楼宇照明监控系统"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="VERSION"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="v1.0.0 · BUILD 2026.04"
                                           Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="Bold"
                                           FontFamily="{StaticResource MonoFontFamily}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="STACK"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text=".NET 6 · WPF · MVVM · SQLite · EF Core"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                           FontFamily="{StaticResource MonoFontFamily}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="AUTHOR"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="周文旭"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="INSTITUTION"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="吉林建筑大学 · JLJU"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="MAJOR"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="计算机科学与技术"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="SUPERVISOR"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="刘钢  ·  王岩"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Background="#CC040812"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="64" Height="64">
                    <Ellipse Style="{StaticResource RotatingArc}" Width="64" Height="64"/>
                    <Ellipse Style="{StaticResource PulseRing}" Width="30" Height="30"/>
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
                <TextBlock Text="LOADING · CONFIG"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource MonoFontFamily}"
                           HorizontalAlignment="Center" Margin="0,22,0,0"/>
                <TextBlock Text="正在加载系统配置"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
