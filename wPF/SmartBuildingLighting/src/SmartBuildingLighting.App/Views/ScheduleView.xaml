<UserControl x:Class="SmartBuildingLighting.App.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SmartBuildingLighting.App.Controls"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:PageHeader Title="定时调度" Code="AUTOMATION / SCHEDULE"
                             Subtitle="基于 Cron 表达式的定时任务 · 支持单回路/分组/情景模式/全楼 多目标调度"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,16,0">
                <Border Background="{StaticResource CardBgGradientBrush}"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="0">
                    <Grid>
                        <Path Style="{StaticResource CornerClipTL}"/>
                        <Path Style="{StaticResource CornerClipTR}"/>
                        <Path Style="{StaticResource CornerClipBL}"/>
                        <Path Style="{StaticResource CornerClipBR}"/>
                        <DataGrid ItemsSource="{Binding Schedules}" SelectedItem="{Binding SelectedSchedule}" Margin="4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="任务名称" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="目标类型" Binding="{Binding TargetType, Converter={StaticResource ScheduleTargetTypeDisplay}}" Width="90"/>
                                <DataGridTextColumn Header="Cron表达式" Binding="{Binding CronExpression}" Width="140"/>
                                <DataGridTextColumn Header="目标状态" Binding="{Binding TargetState, Converter={StaticResource BoolToStatusText}}" Width="70"/>
                                <DataGridTextColumn Header="亮度" Binding="{Binding TargetBrightness, StringFormat={}{0}%}" Width="60"/>
                                <DataGridTextColumn Header="最近执行" Binding="{Binding LastExecutedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140"/>
                                <DataGridTemplateColumn Header="状态" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="8,3" HorizontalAlignment="Left"
                                                    BorderThickness="1"
                                                    BorderBrush="{Binding IsEnabled, Converter={StaticResource BoolToColor}}"
                                                    Background="{Binding IsEnabled, Converter={StaticResource BoolToOnOffColor}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="5" Height="5"
                                                             Fill="{Binding IsEnabled, Converter={StaticResource BoolToColor}}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolToStatusText}}"
                                                               FontSize="10" FontWeight="Bold"
                                                               FontFamily="{StaticResource MonoFontFamily}"
                                                               Foreground="{Binding IsEnabled, Converter={StaticResource BoolToColor}}"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="操作" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="切换" Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10" Margin="0,0,4,0" Tag="{Binding}" Click="ToggleSchedule_Click"/>
                                                <Button Content="删除" Style="{StaticResource DangerButton}" Padding="8,4" FontSize="10" Tag="{Binding}" Click="DeleteSchedule_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
                <Border Background="#200F1E36"
                        BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                        CornerRadius="3" Padding="14" Margin="0,10,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Schedules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="NO TASKS · 暂无定时任务"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="请在右侧新建你的第一个定时任务"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            <!-- ======== 右侧·编辑面板 ======== -->
            <Border Grid.Column="1"
                    Background="{StaticResource CardBgGradientBrush}"
                    BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="20,18">
                <Grid>
                    <Path Style="{StaticResource CornerClipTL}"/>
                    <Path Style="{StaticResource CornerClipBR}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                <TextBlock Text="TASK · EDITOR" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SelectedSchedule.Name, FallbackValue=创建定时任务}" Style="{StaticResource SectionTitle}" Margin="0"/>
                                <Button Grid.Column="1" Content="+ 新建" Style="{StaticResource SecondaryButton}" Command="{Binding StartCreateCommand}" Padding="14,6" FontSize="11" IsEnabled="{Binding CanManage}"/>
                            </Grid>
                            <TextBlock Text="TASK · NAME" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <TextBlock Text="CRON · 表达式" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EditCron, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <TextBlock Text="TARGET · 目标" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding ScheduleTargetTypes}" SelectedItem="{Binding SelectedTargetType}" Margin="0,0,0,12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource ScheduleTargetTypeDisplay}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <ComboBox ItemsSource="{Binding Circuits}" SelectedValuePath="Id" SelectedValue="{Binding SelectedCircuitId}" DisplayMemberPath="Name" Margin="0,0,0,12">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTargetType}" Value="Circuit">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTargetType}" Value="Group">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTargetType}" Value="SceneMode">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTargetType}" Value="AllCircuits">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                            <ComboBox ItemsSource="{Binding Groups}" SelectedValuePath="Id" SelectedValue="{Binding SelectedGroupId}" DisplayMemberPath="Name" Margin="0,0,0,12">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTargetType}" Value="Group">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                            <ComboBox ItemsSource="{Binding Modes}" SelectedValuePath="Id" SelectedValue="{Binding SelectedSceneModeId}" DisplayMemberPath="Name" Margin="0,0,0,12">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTargetType}" Value="SceneMode">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton Content="开灯" IsChecked="{Binding EditTargetState}" Margin="0,0,20,0"/>
                                <RadioButton Content="关灯" IsChecked="{Binding EditTargetState, Converter={StaticResource InverseBool}}"/>
                            </StackPanel>
                            <Slider Value="{Binding EditBrightness}" Minimum="0" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="True"/>
                            <TextBlock Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="11" Margin="0,4,0,16">
                                <Run Text="目标亮度 "/>
                                <Run Text="{Binding EditBrightness}"/>
                                <Run Text="%" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>
                            <Button Content="保存任务" Style="{StaticResource PrimaryButton}" Command="{Binding SaveScheduleCommand}" IsEnabled="{Binding CanManage}"/>
                            <Border Background="#300F1E36"
                                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                    CornerRadius="3" Padding="10,7" Margin="0,12,0,0"
                                    Visibility="{Binding Message, Converter={StaticResource NullToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="11"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Height="1" Background="{StaticResource PrimaryLightBrush}" Margin="0,22,0,18"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Ellipse Style="{StaticResource StatusDotOnline}" VerticalAlignment="Center"/>
                                <TextBlock Text="EXECUTION · LOG" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="最近执行记录" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding ExecutionRecords}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Margin="0,0,0,6"
                                                Background="{StaticResource BgLightBrush}"
                                                BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                                                CornerRadius="3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ExecutedAt, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                                           Foreground="{StaticResource AccentBrush}" FontSize="11"
                                                           FontFamily="{StaticResource MonoFontFamily}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Message}"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.RowSpan="2"
                Background="#CC040812"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="64" Height="64">
                    <Ellipse Style="{StaticResource RotatingArc}" Width="64" Height="64"/>
                    <Ellipse Style="{StaticResource PulseRing}" Width="30" Height="30"/>
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
                <TextBlock Text="LOADING · TASKS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource MonoFontFamily}"
                           HorizontalAlignment="Center" Margin="0,22,0,0"/>
                <TextBlock Text="正在加载定时任务"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
