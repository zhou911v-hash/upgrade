<UserControl x:Class="SmartBuildingLighting.App.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SmartBuildingLighting.App.Controls"
             Loaded="UserControl_Loaded">
    <Grid>
        <StackPanel>
            <controls:PageHeader Title="操作日志" Code="AUDIT / LOG"
                                 Subtitle="系统所有操作记录 · 支持按时间区间筛选 · 分页浏览"/>
            <!-- 筛选条 -->
            <Border Background="{StaticResource CardBgGradientBrush}"
                    BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="18,14" Margin="0,0,0,14">
                <Grid>
                    <Path Style="{StaticResource CornerClipTL}"/>
                    <Path Style="{StaticResource CornerClipBR}"/>
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                            <Ellipse Style="{StaticResource StatusDotAccent}" VerticalAlignment="Center"/>
                            <TextBlock Text="FILTER" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="起始 · FROM" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Grid.Column="2" SelectedDate="{Binding FilterStartDate}" Width="130" Margin="0,0,16,0"/>
                        <TextBlock Grid.Column="3" Text="结束 · TO" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Grid.Column="4" SelectedDate="{Binding FilterEndDate}" Width="130" Margin="0,0,16,0"/>
                        <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="▸ 筛选" Style="{StaticResource PrimaryButton}" Command="{Binding FilterCommand}" Padding="18,7" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            <!-- DataGrid -->
            <Border Background="{StaticResource CardBgGradientBrush}"
                    BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="6">
                <Grid>
                    <Path Style="{StaticResource CornerClipTL}"/>
                    <Path Style="{StaticResource CornerClipTR}"/>
                    <Path Style="{StaticResource CornerClipBL}"/>
                    <Path Style="{StaticResource CornerClipBR}"/>
                    <DataGrid ItemsSource="{Binding Logs}" MaxHeight="520" Margin="10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding OperationTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="180"/>
                            <DataGridTextColumn Header="操作类型" Binding="{Binding OperationType}" Width="110"/>
                            <DataGridTextColumn Header="操作描述" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="目标" Binding="{Binding TargetName}" Width="150"/>
                            <DataGridTextColumn Header="操作人" Binding="{Binding User.DisplayName}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <Border Background="#200F1E36"
                    BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                    CornerRadius="3" Padding="14" Margin="0,10,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Logs.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11" HorizontalAlignment="Center">
                    NO LOGS · 当前筛选条件下暂无日志
                </TextBlock>
            </Border>
            <!-- 分页栏 -->
            <Border Background="{StaticResource CardBgGradientBrush}"
                    BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="16,10" Margin="0,14,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◈" Foreground="{StaticResource AccentBrush}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="{StaticResource MonoFontFamily}" FontSize="11"
                                   Margin="8,0,0,0">
                            <Run Text="TOTAL · " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="{Binding TotalCount}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                            <Run Text="   PAGE · " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="{Binding CurrentPage}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold"/>
                            <Run Text="/" Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="{Binding TotalPages}" Foreground="{StaticResource TextMutedBrush}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="◂ 上一页" Style="{StaticResource SecondaryButton}" Command="{Binding PrevPageCommand}" Padding="14,6" FontSize="11" Margin="0,0,8,0"/>
                        <Button Content="下一页 ▸" Style="{StaticResource SecondaryButton}" Command="{Binding NextPageCommand}" Padding="14,6" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
        <Border Background="#CC040812"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="64" Height="64">
                    <Ellipse Style="{StaticResource RotatingArc}" Width="64" Height="64"/>
                    <Ellipse Style="{StaticResource PulseRing}" Width="30" Height="30"/>
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
                <TextBlock Text="LOADING · LOGS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource MonoFontFamily}"
                           HorizontalAlignment="Center" Margin="0,22,0,0"/>
                <TextBlock Text="正在加载日志"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
