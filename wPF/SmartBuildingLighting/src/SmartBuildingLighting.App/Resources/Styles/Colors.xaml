<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ============================================================
         科技工业风 · 深色色板 (Industrial Dark HUD)
         灵感：Tesla 车机 / Bloomberg Terminal / SpaceX Mission Control
         ============================================================ -->
    <!-- 基础背景层级（从最深到最浅） -->
    <Color x:Key="BgDeepColor">#040812</Color>
    <!-- 窗口最外层 -->
    <Color x:Key="BgDarkColor">#070E1E</Color>
    <!-- 主背景 -->
    <Color x:Key="BgColor">#0A1628</Color>
    <!-- 侧栏/标题栏 -->
    <Color x:Key="BgCardColor">#0F1E36</Color>
    <!-- 卡片面板 -->
    <Color x:Key="BgLightColor">#152942</Color>
    <!-- hover/二级面板 -->
    <Color x:Key="BgHighlightColor">#1C3555</Color>
    <!-- 选中状态 -->
    <!-- 传统映射（保持与旧代码兼容） -->
    <Color x:Key="PrimaryColor">#0F1E36</Color>
    <Color x:Key="PrimaryDarkColor">#070E1E</Color>
    <Color x:Key="PrimaryLightColor">#1E3A5F</Color>
    <!-- 描边/分隔线 -->
    <!-- ========== 霓虹强调色（青色主调 - cyan HUD） ========== -->
    <Color x:Key="AccentColor">#00E5FF</Color>
    <!-- 主青色霓虹 -->
    <Color x:Key="AccentDarkColor">#00A8CC</Color>
    <Color x:Key="AccentLightColor">#7BE4FF</Color>
    <Color x:Key="AccentGlowColor">#5000E5FF</Color>
    <!-- 发光用（32 透明度） -->
    <!-- 状态色（工业警示系） -->
    <Color x:Key="SuccessColor">#00FF88</Color>
    <!-- 荧光运行绿 -->
    <Color x:Key="SuccessGlowColor">#5000FF88</Color>
    <Color x:Key="WarningColor">#FFB020</Color>
    <!-- 工业警示橙 -->
    <Color x:Key="WarningGlowColor">#50FFB020</Color>
    <Color x:Key="DangerColor">#FF3B5C</Color>
    <!-- 故障红 -->
    <Color x:Key="DangerGlowColor">#50FF3B5C</Color>
    <Color x:Key="InfoColor">#4DD0FF</Color>
    <!-- ========== 文字层级（冷白 → 蓝灰 → 暗蓝） ========== -->
    <Color x:Key="TextPrimaryColor">#E8F4FF</Color>
    <Color x:Key="TextSecondaryColor">#8AA9C9</Color>
    <Color x:Key="TextMutedColor">#4A6880</Color>
    <Color x:Key="TextDataColor">#00E5FF</Color>
    <!-- 数据强调色 -->
    <!-- 网格/描边 -->
    <Color x:Key="GridLineColor">#14283E</Color>
    <Color x:Key="GridDotColor">#1E3A5F</Color>
    <!-- ============================================================
         SolidColorBrush 定义
         ============================================================ -->
    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDarkColor}"/>
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgLightBrush" Color="{StaticResource BgLightColor}"/>
    <SolidColorBrush x:Key="BgHighlightBrush" Color="{StaticResource BgHighlightColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessGlowBrush" Color="{StaticResource SuccessGlowColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningGlowBrush" Color="{StaticResource WarningGlowColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerGlowBrush" Color="{StaticResource DangerGlowColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDataBrush" Color="{StaticResource TextDataColor}"/>
    <SolidColorBrush x:Key="GridLineBrush" Color="{StaticResource GridLineColor}"/>
    <SolidColorBrush x:Key="GridDotBrush" Color="{StaticResource GridDotColor}"/>
    <!-- ============================================================
         渐变画刷 - 用于头部扫描线、卡片 accent 边等
         ============================================================ -->
    <!-- 扫描线渐变（透明 → 青 → 透明） -->
    <LinearGradientBrush x:Key="ScanlineBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="Transparent" Offset="0"/>
        <GradientStop Color="#0000E5FF" Offset="0.2"/>
        <GradientStop Color="#FF00E5FF" Offset="0.5"/>
        <GradientStop Color="#0000E5FF" Offset="0.8"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>
    <!-- 卡片顶部微光 -->
    <LinearGradientBrush x:Key="CardTopGlowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4000E5FF" Offset="0"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>
    <!-- 卡片底色渐变（深→更深） -->
    <LinearGradientBrush x:Key="CardBgGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#141E3657" Offset="0"/>
        <GradientStop Color="#0F1E36" Offset="1"/>
    </LinearGradientBrush>
    <!-- 主背景网格渐变 -->
    <RadialGradientBrush x:Key="BgRadialBrush" Center="0.5,0.3" RadiusX="1.2" RadiusY="0.8">
        <GradientStop Color="#0F2142" Offset="0"/>
        <GradientStop Color="#0A1628" Offset="0.7"/>
        <GradientStop Color="#070E1E" Offset="1"/>
    </RadialGradientBrush>
    <!-- 登录页左侧品牌渐变 -->
    <LinearGradientBrush x:Key="BrandPanelGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A1628" Offset="0"/>
        <GradientStop Color="#152942" Offset="0.5"/>
        <GradientStop Color="#0F1E36" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
