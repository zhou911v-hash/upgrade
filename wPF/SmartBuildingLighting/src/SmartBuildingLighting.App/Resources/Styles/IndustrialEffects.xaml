<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ============================================================
         工业科技风动效库 · Industrial Motion Effects
         ============================================================ -->
    <!-- ========== 扫描线动画 ========== -->
    <!-- 用法：<Border Style="{StaticResource ScanLineBorder}"/> 置于卡片顶部 -->
    <Style x:Key="ScanLineBorder" TargetType="Border">
        <Setter Property="Height" Value="2"/>
        <Setter Property="Background" Value="{StaticResource ScanlineBrush}"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Width" Value="200"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="RenderTransformOrigin" Value="0,0"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="-200"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"
                                         From="-200" To="2000"
                                         Duration="0:0:6">
                            <DoubleAnimation.EasingFunction>
                                <QuadraticEase EasingMode="EaseInOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- ========== 呼吸状态灯 ========== -->
    <!-- 用法：<Ellipse Style="{StaticResource StatusDotOnline}"/> -->
    <Style x:Key="StatusDotOnline" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00FF88" BlurRadius="12" ShadowDepth="0" Opacity="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1" To="0.4"
                                         Duration="0:0:1.1">
                            <DoubleAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- 警告状态灯（橙色呼吸） -->
    <Style x:Key="StatusDotWarning" TargetType="Ellipse" BasedOn="{StaticResource StatusDotOnline}">
        <Setter Property="Fill" Value="{StaticResource WarningBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FFB020" BlurRadius="12" ShadowDepth="0" Opacity="1"/>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- 故障状态灯（红色快速闪烁） -->
    <Style x:Key="StatusDotDanger" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF3B5C" BlurRadius="12" ShadowDepth="0" Opacity="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1" To="0.2"
                                         Duration="0:0:0.5">
                            <DoubleAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- 青色（Accent）呼吸灯 -->
    <Style x:Key="StatusDotAccent" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0" Opacity="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1" To="0.5"
                                         Duration="0:0:1.4">
                            <DoubleAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- ========== 脉冲圆环（大尺寸，卡片/logo用） ========== -->
    <Style x:Key="PulseRing" TargetType="Ellipse">
        <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                         From="0.7" To="1.6"
                                         Duration="0:0:2.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                         From="0.7" To="1.6"
                                         Duration="0:0:2.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.9" To="0"
                                         Duration="0:0:2.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- ========== 发光 Logo 框 ========== -->
    <Style x:Key="GlowLogoBorder" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00E5FF" BlurRadius="24" ShadowDepth="0" Opacity="0.75"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                         From="16" To="34"
                                         Duration="0:0:2.4">
                            <DoubleAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                         From="0.5" To="1"
                                         Duration="0:0:2.4">
                            <DoubleAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- ========== 工业斜角装饰框（corner clip） ========== -->
    <!-- 用法：把这个作为 Border 的装饰层放在 HUD 卡片内层 -->
    <Style x:Key="CornerClipTL" TargetType="Path">
        <Setter Property="Data" Value="M0,12 L0,0 L12,0"/>
        <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="4"/>
    </Style>
    <Style x:Key="CornerClipTR" TargetType="Path">
        <Setter Property="Data" Value="M0,0 L12,0 L12,12"/>
        <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="4"/>
    </Style>
    <Style x:Key="CornerClipBL" TargetType="Path">
        <Setter Property="Data" Value="M0,0 L0,12 L12,12"/>
        <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="4"/>
    </Style>
    <Style x:Key="CornerClipBR" TargetType="Path">
        <Setter Property="Data" Value="M0,12 L12,12 L12,0"/>
        <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="4"/>
    </Style>
    <!-- ========== 网格背景（点阵 pattern） ========== -->
    <DrawingBrush x:Key="GridDotPattern"
                  Viewport="0,0,32,32"
                  ViewportUnits="Absolute"
                  TileMode="Tile">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#1E3A5F">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="0.8" RadiusY="0.8"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <!-- ========== 线网格（grid lines） ========== -->
    <DrawingBrush x:Key="GridLinePattern"
                  Viewport="0,0,48,48"
                  ViewportUnits="Absolute"
                  TileMode="Tile">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#14283E" Thickness="0.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="48,0"/>
                            <LineGeometry StartPoint="0,0" EndPoint="0,48"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <!-- ========== 卡片数字发光效果 ========== -->
    <Style x:Key="GlowDataText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ========== 旋转指示器（loading spinner） ========== -->
    <Style x:Key="RotatingArc" TargetType="Ellipse">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="StrokeDashArray" Value="8 4 2 4"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <RotateTransform Angle="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                         From="0" To="360"
                                         Duration="0:0:3"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- ========== 数据走线（从上至下的流光） ========== -->
    <Style x:Key="DataFlowLine" TargetType="Border">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#00E5FF" Offset="0.5"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="-24"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.Y)"
                                         From="-24" To="300"
                                         Duration="0:0:2.5"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    <!-- ========== 边框渐变流动（marquee border） ========== -->
    <Style x:Key="MarqueeBorder" TargetType="Border">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#00E5FF" Offset="0.5"/>
                    <GradientStop Color="#1E3A5F" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
